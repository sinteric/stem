    cell(CVL Certs. # 203 3 and # 203 4 ; key agreement; key establishment methodology provides between 112 and 256 bits of encryption strength)
  }
  row{
    cell(RSA Key Transport)
    cell(K ey establishment methodology provides between 112 and 256 bits of encryption strength)
  }
  row{
    cell(MD5)
    cell(When used with the TLS protocol version 1.0 and 1.1)
  }
  row{
    cell(NDRNG)
    cell(Used only to seed the Approved DRBG)
  }
}
